{
	"name": "axis",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^5",
			"@types/node": "^22.13.14",
			"@orpc/server": "^1.12.2",
			"@orpc/client": "^1.12.2",
			"@orpc/openapi": "^1.12.2",
			"@orpc/zod": "^1.12.2",
			"better-auth": "^1.4.18"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"db:push": "turbo -F @axis/db db:push",
		"db:studio": "turbo -F @axis/db db:studio",
		"db:generate": "turbo -F @axis/db db:generate",
		"db:migrate": "turbo -F @axis/db db:migrate",
		"db:start": "turbo -F @axis/db db:start",
		"db:watch": "turbo -F @axis/db db:watch",
		"db:stop": "turbo -F @axis/db db:stop",
		"db:down": "turbo -F @axis/db db:down",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@axis/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@axis/config": "workspace:*",
		"@biomejs/biome": "^2.2.0",
		"@types/node": "catalog:",
		"turbo": "^2.6.3",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.2.20"
}
